---
interface Props {
  cols?: 2 | 3;
}
const { cols = 3 } = Astro.props;
---

<div class="card-grid" data-cols={cols}>
  <slot />
</div>

<style>
  .card-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
  }
  .card-grid > :global(*) {
    width: 100%;
  }
  @media (min-width: 640px) {
    .card-grid > :global(*) {
      width: calc(50% - 0.625rem);
    }
  }
  @media (min-width: 1024px) {
    .card-grid[data-cols="3"] > :global(*) {
      width: calc(33.333% - 0.8333rem);
    }
  }
</style>
