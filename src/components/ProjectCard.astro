---
interface Props {
  name: string;
  description?: string;
  tags: string[];
  href?: string;
  github?: string;
  status?: 'active' | 'shipped' | 'building' | 'wip';
  highlight?: boolean;
}

const {
  name,
  description,
  tags,
  href,
  github,
  status = 'active',
  highlight = false,
} = Astro.props;

const statusConfig = {
  active: { label: 'Active', color: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20' },
  shipped: { label: 'Shipped', color: 'text-blue-400 bg-blue-400/10 border-blue-400/20' },
  building: { label: 'Building', color: 'text-amber-400 bg-amber-400/10 border-amber-400/20' },
  wip: { label: 'WIP', color: 'text-muted bg-surface-2 border-border' },
};
---

<div
  class:list={[
    'group relative flex flex-col p-5 rounded-xl border transition-all duration-300',
    highlight
      ? 'bg-accent/5 border-accent/30 hover:border-accent/60 hover:bg-accent/10'
      : 'bg-surface border-border hover:border-border-hover hover:bg-surface-2',
  ]}
>
  <!-- Status badge -->
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-display font-semibold text-ink text-base leading-tight group-hover:text-accent-light transition-colors duration-200">
      {name}
    </h3>
    <span
      class:list={[
        'shrink-0 text-xs font-mono px-2 py-0.5 rounded-full border',
        statusConfig[status].color,
      ]}
    >
      {statusConfig[status].label}
    </span>
  </div>

  {description && (
    <p class="text-muted text-sm leading-relaxed flex-1 mb-4">
      {description}
    </p>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-4">
    {
      tags.map((tag) => (
        <span class="text-xs font-mono text-muted-2 bg-surface-2 border border-border px-2 py-0.5 rounded">
          {tag}
        </span>
      ))
    }
  </div>

  <!-- Links -->
  {
    (href || github) && (
      <div class="flex gap-3 mt-auto">
        {href && (
          <a
            href={href}
            target={href.startsWith('http') ? '_blank' : undefined}
            rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="text-xs font-medium text-accent-light hover:text-accent-bright transition-colors flex items-center gap-1"
          >
            View →
          </a>
        )}
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-medium text-muted hover:text-ink transition-colors flex items-center gap-1.5"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
            Source
          </a>
        )}
      </div>
    )
  }
</div>
