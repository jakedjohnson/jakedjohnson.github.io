---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import CardGrid from '../components/CardGrid.astro';

const path = Astro.url.pathname;

const whatIDo = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: 'Internal Tooling & Knowledge Systems',
    body: 'Building the tools that make entire organizations smarter. Central knowledge repositories, agent-assisted workflows, and systems that connect the people who have answers with the people who need them. Breaking down silos is the work I keep gravitating toward.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    title: 'AI Agent Systems',
    body: 'Building agent architectures that maintain state across sessions, learn from their own usage, and fail gracefully under context pressure. OTP patterns applied to multi-agent coordination.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/></svg>`,
    title: 'Real-World Systems Modeling',
    body: 'I turn physical systems into software. Celestial mechanics. House structures. Power systems. If a real-world system has rules, it can be modeled — and a good model is the beginning of understanding.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    title: 'Elixir / BEAM',
    body: '8+ years on the BEAM. OTP supervision trees, GenServer-as-infrastructure, Phoenix LiveView, distributed systems. The conviction that Erlang got fault tolerance right and the rest of us are still catching up.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="7" height="7" rx="1"/><rect x="15" y="3" width="7" height="7" rx="1"/><rect x="2" y="14" width="7" height="7" rx="1"/><rect x="15" y="14" width="7" height="7" rx="1"/><path d="M9 6.5h6M9 17.5h6M5.5 10v4M18.5 10v4"/></svg>`,
    title: 'Integrations & Adapter Layers',
    body: 'I love the glue. Flexible adapter layers, data normalization, schema modeling across disparate systems. Turning vendor APIs, clinical data standards, and third-party platforms into something coherent your own code can reason about.',
  },
];
---

<Layout>
  <Nav currentPath={path} />

  <main>
    <!-- ──────────── HERO ──────────── -->
    <section
      class="relative min-h-screen flex items-center pt-14 overflow-hidden"
    >
      <!-- Background: grid + glow -->
      <div
        class="absolute inset-0 bg-grid-pattern bg-grid opacity-100"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-0 bg-hero-glow"
        aria-hidden="true"
      ></div>
      <!-- Bottom fade into next section -->
      <div
        class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-bg"
        aria-hidden="true"
      ></div>
      <!-- Scroll hint -->
      <div class="absolute bottom-14 left-0 right-0 flex justify-center" aria-hidden="true">
        <div class="animate-bounce text-muted opacity-70">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-8 py-24 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-16 items-center">

          <!-- Text -->
          <div class="space-y-6 text-center lg:text-left">
            <!-- Role chips -->
            <div class="flex flex-wrap gap-2 justify-center lg:justify-start">
              {
                ['Senior Software Engineer', 'AI Agent Systems', 'Digital Twin Architect', 'Elixir/BEAM'].map((chip) => (
                  <span class="text-xs font-mono text-accent-light bg-accent/10 border border-accent/20 px-3 py-1 rounded-full">
                    {chip}
                  </span>
                ))
              }
            </div>

            <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-ink leading-tight tracking-tight">
              Jake Johnson
            </h1>

            <p class="text-xl text-muted leading-relaxed max-w-xl mx-auto lg:mx-0">
              E-commerce tax integrations, healthcare systems, celestial mechanics, agentic infrastructure — I build adapter layers and internal tools that bust down knowledge silos and help teams accelerate.
            </p>

            <p class="font-mono text-sm text-muted-2 italic">
              "Jack of All Trades, Mediocre at Some."
            </p>

            <p class="font-mono text-xs text-muted-2">
              aries sun · gemini moon · leo rising
            </p>

            <div class="flex flex-wrap gap-3 pt-2 justify-center lg:justify-start">
              <a
                href="/projects"
                class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white font-medium px-5 py-2.5 rounded-lg transition-colors duration-200 text-sm"
              >
                View Projects
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a
                href="https://github.com/jakedjohnson"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-surface-2 hover:bg-border text-ink font-medium px-5 py-2.5 rounded-lg border border-border transition-colors duration-200 text-sm"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </a>
              <a
                href="https://www.linkedin.com/in/jacobdjohnson/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-surface-2 hover:bg-border text-muted hover:text-ink font-medium px-5 py-2.5 rounded-lg border border-border transition-colors duration-200 text-sm"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Photo -->
          <div class="flex justify-center lg:justify-end">
            <div class="relative">
              <!-- Glow ring behind photo -->
              <div
                class="absolute inset-0 rounded-full bg-accent/20 blur-2xl scale-110"
                aria-hidden="true"
              ></div>
              <div class="relative w-52 h-52 rounded-full border-2 border-accent/30 overflow-hidden bg-surface-2">
                <!-- If jake.jpg exists in public/images/, it loads. Otherwise shows placeholder. -->
                <img
                  src="/images/ProfilePhoto2026.jpg"
                  alt="Jake Johnson"
                  class="w-full h-full object-cover object-top"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <!-- Placeholder (hidden when photo loads) -->
                <div
                  class="absolute inset-0 flex flex-col items-center justify-center text-muted-2 text-sm font-mono"
                  style="display: none;"
                  aria-hidden="true"
                >
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-40">
                    <circle cx="12" cy="8" r="4"/>
                    <path d="M20 21a8 8 0 1 0-16 0"/>
                  </svg>
                  <span class="opacity-30 text-xs">jake.jpg</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ──────────── WHAT I DO ──────────── -->
    <section class="max-w-5xl mx-auto px-4 sm:px-8 py-24">
      <div class="mb-12">
        <span class="font-mono text-xs text-accent-light tracking-widest uppercase">What I Do</span>
        <h2 class="font-display font-bold text-3xl text-ink mt-2">
          Systems thinking across domains
        </h2>
        <p class="text-muted mt-3 max-w-xl">
          I've never stayed in one lane. Healthcare, astronomy, AI agent infrastructure, DIY engineering — the thread isn't the domain, it's the model.
        </p>
      </div>

      <CardGrid cols={3}>
        {
          whatIDo.map(({ icon, title, body }) => (
            <div class="group p-6 rounded-xl bg-surface border border-border hover:border-border-hover hover:bg-surface-2 transition-all duration-300">
              <div
                class="text-accent-light mb-4 group-hover:text-accent-bright transition-colors duration-200"
                set:html={icon}
              />
              <h3 class="font-display font-semibold text-ink text-base mb-2">{title}</h3>
              <p class="text-muted text-sm leading-relaxed">{body}</p>
            </div>
          ))
        }
      </CardGrid>
    </section>

    <!-- ──────────── CURRENTLY ──────────── -->
    <section class="max-w-5xl mx-auto px-4 sm:px-8 py-16 border-t border-border/40">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <span class="font-mono text-xs text-accent-light tracking-widest uppercase">Currently</span>
          <h2 class="font-display font-bold text-2xl text-ink mt-2 mb-5">What I'm working on</h2>
          <ul class="space-y-4">
            {
              [
                { org: 'Ethermed', role: 'Senior Elixir SWE', detail: 'Healthcare technology — prior authorization, clinical workflow systems.' },
                { org: 'Turning Sky Labs', role: 'Founder', detail: 'Digital twin of the sky in pure Elixir. Ephemeris computation, real-time 3D streaming, MCP-accessible astronomical data — building toward a platform that correlates celestial mechanics with lived experience.' },
                { org: 'Foxtrot Jellyfish', role: 'Consulting / Open Source', detail: 'Protocol design and AI agent infrastructure. The Substrate. The Cortex.' },
              ].map(({ org, role, detail }) => (
                <li class="flex gap-3">
                  <div class="mt-1 w-1 h-1 rounded-full bg-accent-light shrink-0 ring-4 ring-accent/10" />
                  <div>
                    <div class="flex items-baseline gap-2">
                      <span class="font-display font-semibold text-ink text-sm">{org}</span>
                      <span class="text-xs font-mono text-muted-2">{role}</span>
                    </div>
                    <p class="text-muted text-sm mt-0.5">{detail}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <span class="font-mono text-xs text-accent-light tracking-widest uppercase">Background</span>
          <h2 class="font-display font-bold text-2xl text-ink mt-2 mb-5">The long arc</h2>
          <div class="space-y-3 text-sm text-muted leading-relaxed">
            <p>
              Film school at Augsburg, coding bootcamp in Seattle, first production Elixir at Revelry Labs. Built e-commerce data normalization at TaxJar, rode the acquisition into Stripe, then went deep on healthcare — scheduling and referral networks at Blockit/Alluvium, now prior authorization at Ethermed.
            </p>
            <p>
              The constant across every role: abstracting integration layers away from core systems so teams can work with clean, normalized data instead of fighting vendor APIs. I love internal tooling — breaking down knowledge silos and building the systems that make an entire organization smarter and faster.
            </p>
            <p>
              Eight years on the BEAM. Lately, convinced that the same rigor that makes OTP great for distributed systems also makes it the right substrate for multi-agent AI — and the right way to connect people who have answers with people who need them.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ──────────── FOOTER ──────────── -->
    <footer class="border-t border-border/40 mt-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-8 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-mono text-xs text-muted-2">
          minneapolis, mn
        </span>
        <div class="flex items-center gap-5">
          <a
            href="https://github.com/jakedjohnson"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-2 hover:text-ink transition-colors duration-200 text-xs font-mono"
          >
            github
          </a>
          <a
            href="https://www.linkedin.com/in/jacobdjohnson/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-2 hover:text-ink transition-colors duration-200 text-xs font-mono"
          >
            linkedin
          </a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
