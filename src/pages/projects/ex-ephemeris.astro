---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const path = Astro.url.pathname;
---

<Layout
  title="ExEphemeris"
  description="Real-time 3D celestial sphere visualization. Planetary positions computed in pure Elixir, streamed live via Phoenix Channels, rendered in the browser with React Three Fiber."
>
  <Nav currentPath={path} />

  <main class="pt-14">

    <!-- ── HERO ── -->
    <section class="relative min-h-[calc(100vh-3.5rem)] flex items-center overflow-hidden">
      <!-- Background grid + glow (matches homepage) -->
      <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-100" aria-hidden="true"></div>
      <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-bg" aria-hidden="true"></div>
      <!-- Scroll hint -->
      <div class="absolute bottom-14 left-0 right-0 flex justify-center" aria-hidden="true">
        <div class="animate-bounce text-muted opacity-70">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
      </div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-8 py-8 w-full">
        <!-- Back / Live Demo row -->
        <div class="flex items-center justify-between mb-10">
          <a
            href="/projects"
            class="inline-flex items-center gap-1.5 text-xs font-mono text-muted-2 hover:text-ink transition-colors duration-200 group"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            projects
          </a>
          <a
            href="https://ex-ephemeris.fly.dev/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white font-medium px-5 py-2.5 rounded-lg transition-colors duration-200 text-sm"
          >
            Live Demo
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"/>
              <polyline points="7 7 17 7 17 17"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- Text -->
          <div class="space-y-5">
            <div class="flex flex-wrap gap-2">
              {['Phoenix', 'React Three Fiber', 'WebGL', 'Phoenix Channels', 'Elixir', 'OTP', 'NASA/JPL', 'fly.io'].map((t) => (
                <span class="text-xs font-mono text-accent-light bg-accent/10 border border-accent/20 px-3 py-1 rounded-full">{t}</span>
              ))}
            </div>
            <h1 class="font-display font-bold text-4xl sm:text-5xl text-ink leading-tight">
              ExEphemeris
            </h1>
            <p class="text-lg text-muted leading-relaxed">
              A real-time, topocentric celestial sphere. Planetary positions computed from NASA/JPL data in pure Elixir — no C bindings — streamed live via Phoenix Channels and rendered as an interactive 3D scene in the browser.
            </p>
          </div>

          <!-- Screenshot -->
          <div class="relative">
            <div class="absolute inset-0 rounded-xl bg-accent/10 blur-2xl scale-105" aria-hidden="true"></div>
            <div class="relative rounded-xl overflow-hidden border border-border/60 shadow-2xl shadow-black/50">
              <img
                src="/images/ex-ephemeris-demo.png"
                alt="ExEphemeris live demo — real-time 3D celestial sphere with planetary positions, great circles, and BEAM VM metrics"
                class="w-full block"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-4 sm:px-8 py-20">

      <!-- What it does -->
      <section class="mb-16">
        <div class="mb-6">
          <span class="font-mono text-xs text-accent-light tracking-widest uppercase">Overview</span>
          <h2 class="font-display font-bold text-2xl text-ink mt-2">What it does</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {[
            {
              name: 'Compute',
              body: 'A private Elixir library parses binary NASA/JPL ephemeris files and evaluates planetary positions using the same data that powers space mission planning — no NIFs, no C dependencies.',
            },
            {
              name: 'Stream',
              body: 'A Phoenix application wraps the engine with a WebSocket channel, pushing live position snapshots to connected clients at up to 10 Hz. Each frame includes sky coordinates, solar system geometry, and live BEAM VM telemetry.',
            },
            {
              name: 'Render',
              body: 'A React Three Fiber frontend renders the celestial sphere in WebGL — body markers, great circles (horizon, meridian, ecliptic), an Earth globe, an orrery, and transport controls for scrubbing through time.',
            },
          ].map(({ name, body }) => (
            <div class="p-5 rounded-xl bg-surface border border-border">
              <p class="font-mono text-xs text-accent-light mb-3 uppercase tracking-widest">{name}</p>
              <p class="text-sm text-muted leading-relaxed">{body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Why interesting -->
      <section class="mb-16">
        <div class="mb-6">
          <span class="font-mono text-xs text-accent-light tracking-widest uppercase">What's interesting</span>
          <h2 class="font-display font-bold text-2xl text-ink mt-2">Pure BEAM, all the way down</h2>
          <p class="text-muted mt-2 max-w-2xl text-sm leading-relaxed">
            Scientific computing has historically lived in C, Python, and Fortran. This project is an argument that the BEAM is a legitimate substrate for it — and that OTP patterns make real-time scientific streaming cleaner than you'd expect.
          </p>
        </div>
        <ul class="space-y-3">
          {[
            'Parses a binary NASA data format that has been on every JPL interplanetary mission since the 1980s — in native Elixir pattern matching',
            'Loads a scientific dataset into ETS at boot and serves hot-path queries from memory at O(1)',
            'Uses a GenServer as a time machine — ticking through astronomical time at variable speed, computing real physics at every step',
            'Exposes live BEAM VM internals in the UI — memory, process count, scheduler load — so the runtime is part of the demo',
          ].map((item) => (
            <li class="flex gap-3 text-sm text-muted">
              <span class="text-accent-light shrink-0 mt-0.5">→</span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <!-- Differentiation -->
      <section class="mb-16">
        <div class="mb-6">
          <span class="font-mono text-xs text-accent-light tracking-widest uppercase">Landscape</span>
          <h2 class="font-display font-bold text-2xl text-ink mt-2">vs existing tools</h2>
        </div>
        <div class="rounded-xl bg-surface border border-border overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-border/60">
                  <th class="text-left px-5 py-3 font-mono text-xs text-muted-2 uppercase tracking-widest">Tool</th>
                  <th class="text-left px-4 py-3 font-mono text-xs text-muted-2 uppercase tracking-widest">Language</th>
                  <th class="text-center px-4 py-3 font-mono text-xs text-muted-2 uppercase tracking-widest">Topocentric</th>
                  <th class="text-center px-4 py-3 font-mono text-xs text-muted-2 uppercase tracking-widest">Real-time streaming</th>
                  <th class="text-center px-4 py-3 font-mono text-xs text-muted-2 uppercase tracking-widest">Pure BEAM</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { tool: 'Swiss Ephemeris', lang: 'C', t: true, s: false, b: false },
                  { tool: 'Skyfield', lang: 'Python', t: true, s: false, b: false },
                  { tool: 'Morphemeris', lang: 'Ruby', t: false, s: false, b: false },
                ].map(({ tool, lang, t, s, b }) => (
                  <tr class="border-b border-border/30 last:border-0">
                    <td class="px-5 py-3 font-mono text-xs text-muted">{tool}</td>
                    <td class="px-4 py-3 text-xs text-muted-2">{lang}</td>
                    <td class="px-4 py-3 text-center"><span class={t ? 'text-emerald-400' : 'text-muted-2'}>{t ? '✓' : '—'}</span></td>
                    <td class="px-4 py-3 text-center"><span class={s ? 'text-emerald-400' : 'text-muted-2'}>{s ? '✓' : '—'}</span></td>
                    <td class="px-4 py-3 text-center"><span class={b ? 'text-emerald-400' : 'text-muted-2'}>{b ? '✓' : '—'}</span></td>
                  </tr>
                ))}
                <tr class="bg-accent/5 border-t border-accent/20">
                  <td class="px-5 py-3 font-mono text-xs text-accent-light font-medium">eph_core</td>
                  <td class="px-4 py-3 text-xs text-accent-light">Elixir</td>
                  <td class="px-4 py-3 text-center text-emerald-400">✓</td>
                  <td class="px-4 py-3 text-center text-emerald-400">✓</td>
                  <td class="px-4 py-3 text-center text-emerald-400">✓</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- This is a piece of Turning Sky -->
      <section class="mb-16">
        <div class="p-6 rounded-xl bg-surface border border-border/60">
          <p class="font-mono text-xs text-muted-2 uppercase tracking-widest mb-3">Context</p>
          <p class="text-sm text-muted leading-relaxed">
            ExEphemeris is the public demo surface of <a href="https://turningskylabs.com" target="_blank" rel="noopener noreferrer" class="text-accent-light hover:text-accent-bright transition-colors">Turning Sky Labs</a> — one integration layer in a larger platform building a unified, time-indexed ledger of real-world events, with the same engine being developed as an MCP server for agent-native astronomical computation.
          </p>
        </div>
      </section>

    </div>

    <!-- Footer -->
    <footer class="border-t border-border/40 mt-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-8 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-mono text-xs text-muted-2">minneapolis, mn</span>
        <div class="flex items-center gap-5">
          <a href="https://github.com/jakedjohnson" target="_blank" rel="noopener noreferrer" class="text-muted-2 hover:text-ink transition-colors duration-200 text-xs font-mono">github</a>
          <a href="https://www.linkedin.com/in/jacobdjohnson/" target="_blank" rel="noopener noreferrer" class="text-muted-2 hover:text-ink transition-colors duration-200 text-xs font-mono">linkedin</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
